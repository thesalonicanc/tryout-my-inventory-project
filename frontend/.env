# ─────────────────────────────────────────────────────────────
# Frontend Environment Variables — Create React App
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# All variables MUST start with REACT_APP_ to be accessible
# in the browser bundle.
#
# For production (Amplify), set these in:
#   AWS Amplify Console → App settings → Environment variables
# ─────────────────────────────────────────────────────────────

# Your API Gateway Invoke URL + /barang
# Example: https://abc123.execute-api.us-east-1.amazonaws.com/prod/barang
REACT_APP_API_URL=https://YOUR_API_GATEWAY_ID.execute-api.YOUR_REGION.amazonaws.com/prod/barang
